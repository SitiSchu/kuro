{
  "name": "Kuro",
  "dark": true,
  "author": "SitiSchu",
  "editorScheme": "/schemes/kuro.xml",

  "colors": {
    "transparent": "#00000000",
    "foreground": "#c9c9c9",
    "background": "#202020",
    "disabled": "#787878",
    "mainColor": "#e52a57",
    "mainColorDimmed": "#722435"
  },

  "ui": {
    "*": {
      "background": "background",
      "foreground": "foreground",
      "infoForeground": "disabled",
      "successForeground": "#00FF00",
      "selectionBackground": "#af2a49",
      "selectionForeground": "foreground",
      "selectionInactiveBackground": "mainColorDimmed",
      "selectionBackgroundInactive": "mainColorDimmed",
      "disabledBackground": "background",
      "inactiveBackground": "background",
      "disabledForeground": "#5c5c5c",
      "disabledText": "disabled",
      "inactiveForeground": "disabled",
      "borderColor": "background",
      "disabledBorderColor": "background",
      "focusColor": "mainColor",
      "focusedBorderColor": "mainColor",
      "hoverBorderColor": "mainColor",
      "pressedBorderColor": "mainColor",
      "separatorColor": "#252525",
      "lineSeparatorColor": "#222222"
    },

    "ActionButton": {
      "hoverBackground": "background",
      "pressedBackground": "transparent",
      "pressedBorderColor": "#af2a49"
    },

    "Button": {
      "startBackground": "#252525",
      "endBackground": "#252525",
      "startBorderColor": "#252525",
      "endBorderColor": "#252525",

      "default": {
        "foreground": "#000000",
        "startBackground": "mainColor",
        "endBackground": "mainColor",
        "startBorderColor": "mainColor",
        "endBorderColor": "mainColor",
        "focusedBorderColor": "#000000"
      }
    },

    "Borders": {
      "color": "#252525",
      "ContrastBorderColor": "#252525"
    },

    "ComboBox": {
      "nonEditableBackground": "background",
      "modifiedItemForeground": "mainColor",

      "ArrowButton": {
        "iconColor": "#ffffff",
        "disabledIconColor": "#252525",
        "nonEditableBackground": "background"
      }
    },
    "Button.shadowWidth": "0",
    "ComboPopup.border": "1,1,1,1,252525",

    "CompletionPopup": {
      "matchForeground": "foreground",
      "Advertiser.background": "#222222"

    },

    "DefaultTabs": {
      "underlineColor": "mainColor",
      "inactiveUnderlineColor": "mainColorDimmed",
      "underlineHeight": 2,
      "hoverBackground": "#353535",
      "underlinedTabBackground": "#353535"
    },

    "Counter": {
      "background": "mainColor",
      "foreground": "foreground"
    },

    "EditorTabs": {
      "underlinedTabBackground": "background"
    },

    "FileColor": {
      "Yellow": "#F0C67430",
      "Green": "#8C944030",
      "Blue": "#5F819D30",
      "Violet": "#85678F30",
      "Orange": "#DE935F20",
      "Rose": "#A5424230",
      "Gray": "#70788030"
    },

    "Link": {
      "activeForeground": "mainColor",
      "hoverForeground": "mainColor",
      "pressedForeground": "mainColor",
      "visitedForeground": "mainColor",
      "secondaryForeground": "mainColor"
    },

    "MemoryIndicator": {
      "usedBackground": "#404040",
      "allocatedBackground": "#505050"
    },

    "Notification": {
      "background": "#252525"
    },

    "Plugins": {
      "Button": {
        "installForeground": "foreground",
        "installBorderColor": "mainColor",
        "installFillForeground": "foreground",
        "installFillBackground": "mainColor",
        "updateForeground": "foreground",
        "updateBackground": "mainColor"
      },
      "lightSelectionBackground": "mainColorDimmed",
      "hoverBackground": "#353535"
    },

    "Popup": {
      "paintBorder": true,
      "Header.activeBackground": "background",
      "Header.inactiveBackground": "background",

      "Advertiser": {
        "background": "background",
        "borderColor": "background",
        "borderInsets": "3,8,5,0"
      }
    },

    "ProgressBar": {
      "trackColor": "background",
      "progressColor": "mainColor",
      "indeterminateStartColor": "mainColor",
      "indeterminateEndColor": "mainColorDimmed",
      "failedColor": "#CC6666",
      "failedEndColor": "#A54242",
      "passedColor": "#B5BD68",
      "passedEndColor": "#8C9440"
    },

    "ScrollBar": {
      "Transparent": {
        "thumbColor": "mainColorDimmed",
        "thumbBorderColor": "mainColorDimmed",
        "hoverThumbColor": "mainColor",
        "hoverThumbBorderColor": "mainColor"
      },
      "thumbColor": "mainColorDimmed",
      "thumbBorderColor": "mainColorDimmed",
      "hoverThumbColor": "mainColor",
      "hoverThumbBorderColor": "mainColor"
    },
    "StatusBar.borderColor": "background",

    "TabbedPane": {
      "underlineColor": "mainColor",
      "tabSelectionHeight": 2,
      "disabledUnderlineColor": "mainColorDimmed",
      "hoverColor": "#454545",
      "focusColor": "#454545"
    },

    "ToolWindow": {
      "Button": {
        "selectedBackground": "mainColor"
      }
    }
  },

  "icons": {
    "ColorPalette": {
      "Actions.Grey": "foreground",
      "Actions.Red": "#CC6666",
      "Actions.Yellow": "#FFD333",
      "Actions.Green": "#c3e88d",
      "Actions.Blue": "#81A2BE",
      "Actions.GreyInline.Dark": "foreground",
      "Objects.Grey": "foreground",
      "Objects.RedStatus": "#CC6666FF",
      "Objects.Red": "#CC6666FF",
      "Objects.Pink": "mainColor",
      "Objects.Yellow": "#F0C674FF",
      "Objects.Green": "#c3e88dFF",
      "Objects.Blue": "#81A2BEFF",
      "Objects.Purple": "#B294BBFF",
      "Objects.BlackText": "#000000FF",
      "Objects.YellowDark": "#F0C674FF",
      "Objects.GreenAndroid": "#c3e88dFF",
      "Checkbox.Background.Default.Dark": "background",
      "Checkbox.Border.Default.Dark": "mainColor",
      "Checkbox.Foreground.Selected.Dark": "mainColor",
      "Checkbox.Focus.Wide.Dark": "mainColor",
      "Checkbox.Focus.Thin.Default.Dark": "mainColor",
      "Checkbox.Focus.Thin.Selected.Dark": "mainColor",
      "Checkbox.Background.Disabled.Dark": "background",
      "Checkbox.Border.Disabled.Dark": "#252525",
      "Checkbox.Foreground.Disabled.Dark": "#5c5c5c"
    }
  }
}
